const target = "/en/";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href="https://www.3rdproductions.com/en/" />
    <title>third | Moving Image Studio</title>
  </head>
  <body>
    <a href={target}>Continue to third</a>
    <script is:inline>
      window.location.replace("/en/" + window.location.hash);
    </script>
  </body>
</html>
